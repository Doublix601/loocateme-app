{
  "expo": {
    "name": "LoocateMe",
    "slug": "loocateme-app",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appIcons/AppIcon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "loocateme",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/da2f75d4-ab23-4073-8db9-1ab186cc22d6"
    },
    "splash": {
      "image": "./assets/appIcons/AppIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.loocate.app",
      "scheme": "loocateme",
      "associatedDomains": [
        "applinks:api.loocate.me"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "loocate.me": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionRequiresForwardSecrecy": true
            }
          }
        },
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "Votre position est utilisée pour afficher les utilisateurs autour de vous.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Votre position en arrière-plan peut être partagée pendant 6 heures lorsque vous l’activez.",
        "NSLocationAlwaysUsageDescription": "Votre position en arrière-plan peut être partagée pendant 6 heures lorsque vous l’activez.",
        "NSCameraUsageDescription": "LoocateMe utilise votre appareil photo pour prendre une photo de profil ou l'envoyer dans une conversation.",
        "NSPhotoLibraryUsageDescription": "LoocateMe accède à votre photothèque pour choisir une photo de profil ou l'envoyer dans une conversation.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "me.loocate.app",
      "scheme": "loocateme",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.loocate.me",
              "pathPrefix": "/profile"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "useReactNativeNewArchitecture": true,
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/appIcons/AppIcon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Votre position en arrière-plan peut être partagée pendant 6 heures lorsque vous l’activez."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "da2f75d4-ab23-4073-8db9-1ab186cc22d6"
      }
    }
  }
}
