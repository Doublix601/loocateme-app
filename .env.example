# Exemple de fichier .env pour Expo
# Copiez ce fichier en .env et ajustez les valeurs

# L'origine de l'API Backend.
# En développement local avec un simulateur physique, utilisez l'IP locale de votre machine (ex: http://192.168.1.XX:4000)
# EXPO_PUBLIC_API_ORIGIN=http://192.168.1.187:4000

# Clés API publiques RevenueCat (Project settings > API keys dans le dashboard RevenueCat)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
